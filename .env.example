# Beispiel .env Datei für GPS-Gerät
# Kopiere diese Datei nach .env und passe die Werte an

# WLAN-Einstellungen für Webinterface
WIFI_SSID="GPS-Device"
WIFI_PASSWORD="YourSecurePassword123"

# Entwicklung
DEBUG=False
LOG_LEVEL=INFO

# Optional: API-Keys für Wetter-Services, etc.
# OPENWEATHER_API_KEY=your_key_here
